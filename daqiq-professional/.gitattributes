# Normalize line endings to LF in the repo, checkout as LF everywhere
* text=auto eol=lf

# Python and shell always LF
*.py   text eol=lf
*.sh   text eol=lf
*.md   text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.html text eol=lf
*.txt  text eol=lf

# Binaries — no conversion
*.png  binary
*.jpg  binary
*.pdf  binary
*.zip  binary
