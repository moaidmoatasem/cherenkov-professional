│  import asyncio                                                              │
│                                                                              │
│  class AsyncSlack:                                                           │
│      """                                                                     │
│      A class to handle integrating with Slack via WebSocket API.             │
│                                                                              │
│      Attributes:                                                             │
│          slack_websocket_api_token (str): The token for connecting to the    │
│  Slack WebSocket.                                                            │
│          slack_client: The aiohttp client session initialized for WebSocket  │
│  communication.                                                              │
│          _connected_event: Async event that will be set when connected to    │
│  Slack.                                                                      │
│                                                                              │
│      """                                                                     │
│                                                                              │
│      def __init__(self, token):                                              │
│          self.slack_websocket_api_token = token                              │
│          self.slack_client = None                                            │
│          self._connected_event = asyncio.Event()                             │
│                                                                              │
│      async def connect(self):                                                │
│          """Initialize the WebSocket connection."""                          │
│          if not self.slack_client:                                           │
│              import aiohttp                                                  │
│              from aiowebsocketclient.connection import WebsocketClient       │
│                                                                              │
│              params = {                                                      │
│                  'headers': {'Authorization': f'Bearer                       │
│  {self.slack_websocket_api_token}'}                                          │
│              }                                                               │
│              async with aiohttp.ClientSession() as session:                  │
│                  self.slack_client = WebsocketClient(session,                │
│  '/api/groups/events')                                                       │
│                                                                              │
│          await self._connected_event.wait()                                  │
│                                                                              │
│      def event_listener(self, event_type):                                   │
│          """Event listener for a specific type of Slack events.              │
│                                                                              │
│          Args:                                                               │
│              event_type (str): Events like 'hello' to listen to on the       │
│  WebSocket.                                                                  │
│                                                                              │
│          """                                                                 │
│          async def coroutine(event_type_):                                   │
│              event_data = await                                              │
│  self.slack_client.poll(f'/groups/events?types={event_type}_events')         │
│                                                                              │
│              if len(event_data) > 0:                                         │
│                  print('Received {0} Slack                                   │
│  Events:'.format(len(event_data)))                                           │
│                  for ev in event_data:                                       │
│                      print(ev)                                               │
│                                                                              │
│          loop = asyncio.get_event_loop()                                     │
│                                                                              │
│          return loop.create_task(coroutine(event_type))                      │
│                                                                              │
│                                                                              │
│  def example_usage():                                                        │
│      """                                                                     │
│      Example Usage of AsyncSlack to integrate with Slack.                    │
│                                                                              │
│      This shows how you can connect, receive events, and close the           │
│  connection gracefully.                                                      │
│      Example assumes running in a loop as the use case for WebSocket would   │
│  be continuous event listening.                                              │
