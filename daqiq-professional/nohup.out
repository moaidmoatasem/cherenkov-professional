│                                                                              │
│  class RetryManager:                                                         │
│      """                                                                     │
│      Retry Manager is designed to handle smart retries in different          │
│  contexts.                                                                   │
│                                                                              │
│      It supports configuring retry policies (backoff and max attempts) and   │
│      will automatically manage retries under given constraints.              │
│      """                                                                     │
│                                                                              │
│      def __init__(self, attempt_limit=3, backoff_factor=1.0):                │
│          self.attempt_limit = attempt_limit                                  │
│          self.backoff_factor = backoff_factor                                │
│                                                                              │
│      @staticmethod                                                           │
│      def execute_with_retry(caller_fn, caller_args, backoff_time):           │
│          """                                                                 │
│          Executes `caller_fn` a specified number of times as configured by   │
│  the RetryManager.                                                           │
│                                                                              │
│          Args:                                                               │
│              caller_fn: Function to be retried.                              │
│              caller_args: Positional arguments for `caller_fn`.              │
│              backoff_time: Time in seconds to wait before retrying on        │
│  error, starting with 1 second.                                              │
│                                                                              │
│          Returns:                                                            │
│              result of calling `caller_fn` successfully or -1 if a maximum   │
│  of attempts is reached without success.                                     │
│                                                                              │
│          Raises:                                                             │
│              MultiRetryError: If caller_fn raises an exception and max       │
│  retries are exhausted.                                                      │
│          """                                                                 │
│          attempt = 0                                                         │
│          last_exception = None                                               │
│                                                                              │
│          while attempt < RetryManager.attempt_limit:                         │
│              try:                                                            │
│                  return caller_fn(*caller_args)                              │
│              except Exception as e:                                          │
│                  if isinstance(e, MultiRetryError):                          │
│                      raise e                                                 │
│                  else:                                                       │
│                      if attempt > 0:                                         │
│                          delay = min(RetryManager.attempt_limit - (attempt   │
│  - 1),                                                                       │
