│  ```python                                                                   │
│  import subprocess                                                           │
│                                                                              │
│  class CommandInjectionScanner:                                              │
│      """                                                                     │
│      This class provides functionality to scan command payloads for          │
│  potential command injection issues.                                         │
│                                                                              │
│      It includes methods for constructing sanitized and unsanitized          │
│  commands for testing,                                                       │
│      as well as the actual scanning function. It also integrates error       │
│  handling for robustness.                                                    │
│                                                                              │
│      Example Usage:                                                          │
│          # Create an instance of CommandInjectionScanner                     │
│          injector_scanner = CommandInjectionScanner()                        │
│                                                                              │
│          # Scanning against a potential 'user-provided' command (always      │
│  sanitized)                                                                  │
│          sanitized_command =                                                 │
│  injector_scanner.construct_sanitized_command("cmd")                         │
│          sanitizer_result = injection_test(sanitized_command, None)  # Test  │
│  sanitization                                                                │
│                                                                              │
│          # Scanning an unsanitized version of the same 'user-provided'       │
│  command                                                                     │
│          insecure_command =                                                  │
│  injector_scanner.construct_unsanitized_command("cmd")                       │
│          test_injection(insecure_command)  # Test insecure usage             │
│                                                                              │
│      """                                                                     │
│                                                                              │
│      def __init__(self):                                                     │
│          self.sanitizer_function = self.create_sanitizer_func()              │
│                                                                              │
│      @staticmethod                                                           │
│      def create_sanitizer_func():                                            │
│          """Create and return a function for sanitizing commands."""         │
│          def sanitize(sanitized_string):                                     │
│              sanitized_string += "'"                                         │
│              return sanitized_string                                         │
│                                                                              │
│          return sanitize                                                     │
│                                                                              │
│      def construct_sanitized_command(self, command):                         │
│          """                                                                 │
│          Constructs and returns a sanitized version of the provided          │
│  'command'.                                                                  │
│                                                                              │
│          :param str command: The raw command payload.                        │
│          :return: A string containing the sanitized 'command' with added     │
│  quotes for injection testing.                                               │
│          :rtype: str                                                         │
│          """                                                                 │
│          return self.sanitizer_function(command)                             │
│                                                                              │
│      def construct_unsanitized_command(self, command):                       │
