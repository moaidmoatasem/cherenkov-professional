│  from pathlib import Path                                                    │
│                                                                              │
│  class FeatureScanner:                                                       │
│      """                                                                     │
│      A class to perform scanning of features within the codebase.            │
│                                                                              │
│      Methods:                                                                │
│          --scan_project(project_directory): Scans a project directory for    │
