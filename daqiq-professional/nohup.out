│                  server.sendmail(                                            │
│                      "security@example.com",                                 │
│                      ["security@example.com"],                               │
│                      report_message.as_string()                              │
│                  )                                                           │
│              except Exception as e:                                          │
│                  raise ValueError("An error occurred while sending the       │
