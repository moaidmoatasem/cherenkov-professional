│                      "dataFormat": "NVD3.5",                                 │
│                      "dataTypeVersion": "3.4",                               │
│                      "ID": "CVE-2023-1789",                                  │
│                      "modifiedDataTime": "",                                 │
│                      "publishedDate": "2023-05-25T06:32:00.000Z",            │
│                      "lastModifiedDate": "",                                 │
│                       ...                                                    │
│                  },                                                          │
│                   "description": {                                           │
