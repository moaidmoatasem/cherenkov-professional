│  ```python                                                                   │
│  import os                                                                   │
│                                                                              │
│  class PathTraversalScanner:                                                 │
│      """                                                                     │
│      A class to scan directories for possible path traversal                 │
│  vulnerabilities.                                                            │
│                                                                              │
│      The `scan` method takes a directory path and scans it for               │
│  files/folders that lead outside of the specified root directory. It avoids  │
│  scanning itself, as this could inadvertently expose internal paths.         │
│                                                                              │
│      Example usage:                                                          │
│      >>> scanner = PathTraversalScanner("/path/to/root")                     │
│      >>> results = scanner.scan()                                            │
│      >>> print(results)                                                      │
│      """                                                                     │
│                                                                              │
│      def __init__(self, base_directory):                                     │
