│  # Generate a summary from given report files                                │
│  exec_summary = exec_summary_generator.generate_summary("network_scan.xml",  │
│  "openvas_report.json")                                                      │
│  print(exec_summmary)                                                        │
│  ```                                                                         │
│                                                                              │
│  """                                                                         │
│                                                                              │
│  class ExecutiveSummaryGenerator:                                            │
│      def generate_summary(self, *report_files: str) -> str:                  │
│          """                                                                 │
│          Generates an executive summary based on multiple security scan      │
│  reports.                                                                    │
│                                                                              │
│          :param report_files: List of file paths for the .xml or .json       │
│  files.                                                                      │
│          :return: A string containing a summarized report.                   │
│                                                                              │
│          :raises FileNotFoundError: If one or more required files are not    │
│  found.                                                                      │
│          :raises ValueError: If any of the report files do not end in        │
│  '.xml' or '.json'.                                                          │
│          """                                                                 │
│          summary = "Executive Summary:\n\n"                                  │
│                                                                              │
│          for file_path in [f.replace("'", '').replace('"', '') for f in      │
│  report_files]:                                                              │
│              if not file_path.endswith(".xml") and not                       │
│  file_path.endswith(".json"):                                                │
│                  raise ValueError(f"Invalid file format: {file_path}")       │
│                                                                              │
│              try:                                                            │
│                  with open(file_path, 'r') as file:                          │
│                      data = file.read()                                      │
│                      # Actual logic to extract security summary information  │
│  from the report would go here.                                              │
│                      # For demonstration purposes, we'll just return a       │
│  portion of that data.                                                       │
│                      summary += f"Extracted Summary From                     │
│  {file_path}:\n{data[:50]}\n"                                                │
│              except FileNotFoundError:                                       │
│                  raise FileNotFoundError(f"The file was not found:           │
│  {file_path}")                                                               │
│                                                                              │
│          return summary                                                      │
│                                                                              │
│                                                                              │
│  # Example usage function (you would replace this with your own              │
│  implementation or remove it for production)                                 │
│  def basic_example_usage(file_paths,                                         │
│  example_func=ExecutiveSummaryGenerator().generate_summary):                 │
│      print(example_func(*file_paths))                                        │
│                                                                              │
│  import unittest                                                             │
│                                                                              │
│  class TestGenerateSummary(unittest.TestCase):                               │
│                                                                              │
│      def test_basic(self):                                                   │
