│          with self.assertRaises(FileNotFoundError):                          │
│              generator.generate_summary("unknown_file.txt")                  │
│                                                                              │
│          # Simple check to ensure the files are accounted for and processed  │
│          self.assertIn('Extracted Summary From network_scan.xml',            │
│  generator.generate_summary(*example_files))                                 │
│          self.assertIn('Extracted Summary From openvas_report.json',         │
│  generator.generate_summary(*example_files))                                 │
│                                                                              │
