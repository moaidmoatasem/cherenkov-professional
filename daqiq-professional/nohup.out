│          self.pattern_count = 0                                              │
│                                                                              │
│      def add_patterns(self, patterns):                                       │
│          """                                                                 │
│          Adds new attack pattern templates to the object.                    │
│                                                                              │
│          Args:                                                               │
│              patterns (dict): Dictionary with the new attack patterns.       │
│                                                                              │
│          Example call:                                                       │
│                                                                              │
│          >>> detector.add_patterns({'new_pattern': 'Detail explanation of    │
│  the pattern.'})                                                             │
│          >>> detector.pattern_count                                          │
│          4 # Since we added one new pattern, which increments count          │
│                                                                              │
│          Returns:                                                            │
│              None.                                                           │
│                                                                              │
│          """                                                                 │
│          for key, value in patterns.items():                                 │
│              self._patterns[key] = value                                     │
│              self.pattern_count += 1                                         │
│                                                                              │
│      def scan(self, data):                                                   │
│          """                                                                 │
│          Scans the provided data for attack chains matching pre-defined      │
│  patterns.                                                                   │
│                                                                              │
│          Args:                                                               │
│              data (str): The string to be scanned for potential attack       │
│  lines.                                                                      │
│                                                                              │
│          Returns:                                                            │
│              List[dict]: A list containing dictionaries with keys of         │
│  pattern names and their corresponding match descriptions found in the       │
│  provided data. Each dictionary is a finding in case the code matched        │
│  against any of the pre-defined patterns.                                    │
│                                                                              │
│          Example call:                                                       │
│                                                                              │
│          >>> detector = AttackChainDetector()                                │
│          >>> detector.add_patterns({                                         │
│          ...     'unrestricted_access_granted': 'User granted unauthorized   │
│  access to restricted resources.'                                            │
│          ... })                                                              │
│          >>> patterns_found = detector.scan('The attacker took control of    │
│  the database server with this command: UNLIMITED_ACCESS_GRANTED.')          │
│          >>> len(patterns_found)                                             │
│          1                                                                   │
│                                                                              │
│          """                                                                 │
│          import re                                                           │
│          self.pattern_count = sum(pattern in data for pattern in             │
│  list(self._patterns.keys()))                                                │
│                                                                              │
│          # Here we could add more complex regex or logic to find attack      │
│  patterns within the data.                                                   │
│          return [{"pattern_name": key, "description": value} for key, value  │
│  in self._patterns.items() if re.search(fr"\b{key}\b", data)]                │
│                                                                              │
│  def _test():                                                                │
