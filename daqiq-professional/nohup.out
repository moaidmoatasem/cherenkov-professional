│  Certainly! Below is a complete Python code designed to integrate with the   │
│  Common Vulnerabilities and Exposures (CVE) database. The code includes      │
│  error handling, docstrings, examples of usage, and unit tests for           │
│  production-readiness.                                                       │
│                                                                              │
│  ```python                                                                   │
│  import requests                                                             │
│  from urllib.parse import urljoin                                            │
│                                                                              │
│  class CVEScanner:                                                           │
│      """                                                                     │
│      A class to fetch and validate CVE information.                          │
│      """                                                                     │
│                                                                              │
│      def __init__(self):                                                     │
│          self.base_url = "https://services.nvd.nist.gov/rest/json/cves/"     │
│                                                                              │
│      def get_cve(self, cve_id: str) -> dict:                                 │
│          """                                                                 │
│          Fetches the details of a specific CVE.                              │
│                                                                              │
│          :param cve_id (str): The CVE ID.                                    │
│          :return: A dictionary representing the CVE details or None if not   │
│  found.                                                                      │
│          """                                                                 │
│          try:                                                                │
│              response = requests.get(urljoin(self.base_url, str(cve_id)),    │
│  timeout=10)                                                                 │
│              response.raise_for_status()                                     │
│          except requests.RequestException as e:                              │
│              print(f"Request error: {e}")                                    │
│              return None                                                     │
│                                                                              │
│          return response.json()['nvdcve-2.0']['vulnerabilities'][cve_id]     │
│                                                                              │
│      def find_cve(self, vulnerability_name: str) -> list[str]:               │
│          """                                                                 │
│          Searches CVEs matching a specific name and returns them.            │
│                                                                              │
│          :param vulnerability_name (str): The search query.                  │
│          :return: A list of CVE IDs found or an empty list if not found.     │
│          """                                                                 │
│          response = self.get_cve(vulnerability_id=None)                      │
│          if not response:                                                    │
│              return []                                                       │
│                                                                              │
│          vulnerabilities = response['CVE_Items']                             │
│          matches = [item['cve']['CVE_data_meta']['ID'] for item in           │
│  vulnerabilities                                                             │
│                     if vulnerability_name.lower() in                         │
│  item['cve']['summary'].lower()]                                             │
│                                                                              │
│          return matches                                                      │
│                                                                              │
│  # Example of usage                                                          │
│  def example_usage():                                                        │
│                                                                              │
│      scanner = CVEScanner()                                                  │
│                                                                              │
│      # Testing the get_cve method                                            │
│      cve_details1 = scanner.get_cve('CVE-2023-0567')                         │
│      print(f"Details for CVE-2023-0567: {cve_details1}")                     │
│                                                                              │
│      # Testing the find_cve method                                           │
│      matches = scanner.find_cve('SQL database')                              │
│      if matches:                                                             │
│          print(f"Found vulnerability IDs related to SQL databases:           │
│  {matches}")                                                                 │
│      else:                                                                   │
│          print("No matching CVEs found for input.")                          │
│                                                                              │
│  # Unit Tests                                                                │
│                                                                              │
│  def test_get_cve():                                                         │
│      import json                                                             │
│                                                                              │
│      with open('test_data.json', 'r') as file:                               │
│          response_data = json.load(file)                                     │
│                                                                              │
│      scanner = CVEScanner()                                                  │
│                                                                              │
│      test_id = 'CVE-2023-1789'                                               │
│      expected_response =                                                     │
│  response_data['nvdcve-2.0']['vulnerabilities'][test_id]                     │
│      actual_response = scanner.get_cve(test_id)                              │
│                                                                              │
│      assert isinstance(actual_response, dict), "Expected a dictionary from   │
│  the response."                                                              │
│      assert expected_response == actual_response, "Get CVE method returns    │
│  data not matching expected response."                                       │
│                                                                              │
│  def test_find_cve():                                                        │
│      import json                                                             │
│                                                                              │
│      with open('test_data.json', 'r') as file:                               │
│          response_data = json.load(file)                                     │
│                                                                              │
│      scanner = CVEScanner()                                                  │
│                                                                              │
│      expected_matches = ['CVE-2023-1789']                                    │
│      actual_matches = scanner.find_cve("SQL database")                       │
│                                                                              │
│      assert isinstance(actual_matches, list), "Expected a list of matches."  │
│      assert len(expected_matches) == len(actual_matches), "The number of     │
│  matches is not as expected."                                                │
│                                                                              │
│  if __name__ == '__main__':                                                  │
│      # Run tests if this script being run                                    │
│      from unittest import TestCase                                           │
│                                                                              │
│      class CVEScannerTest(TestCase):                                         │
│          def test_get_cve_functionality(self):                               │
│              test_get_cve()                                                  │
│                                                                              │
│          def test_find_cve_functionality(self):                              │
│             test_find_cve()                                                  │
│                                                                              │
│      runner = CVEScannerTest('test_get_cve_functionality')                   │
│      test_output = test_get_cve().__str__([runner])                          │
│      print(test_output)                                                      │
│                                                                              │
│      # Run usage example                                                     │
│      example_usage()                                                         │
│                                                                              │
│  # Example data for testing purposes.                                        │
│  import json                                                                 │
│                                                                              │
│  TEST_DATA = {                                                               │
│      "nvdcve-2.0": {                                                         │
│          "vulnerabilities": {                                                │
│              "CVE-2023-1789": {                                              │
│                  "cve": {                                                    │
