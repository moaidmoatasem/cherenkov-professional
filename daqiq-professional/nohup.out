│          self.api_url = api_url                                              │
│          self.client_id = None  # Can be set externally or as environment    │
│  variable                                                                    │
│          self.token = None     # Can be set externally or as environment     │
│  variable                                                                    │
│                                                                              │
│      def fetch_cves(self, product_name: str) -> List[str]:                   │
│          """                                                                 │
│          Fetch CVEs for a given product name.                                │
│                                                                              │
│          :param product_name: The product/name to look up in the CVE         │
│  database.                                                                   │
│          :return: A list of CVE IDs associated with the provided name.       │
│          """                                                                 │
│                                                                              │
│          params = {                                                          │
│              "name": product_name                                            │
│          }                                                                   │
│                                                                              │
│          url = f"{self.api_url}/search.cfm"                                  │
│                                                                              │
│          headers = self._build_headers()                                     │
│                                                                              │
│          response = requests.get(url, headers=headers, params=params)        │
│          if not response.ok:                                                 │
│              raise Exception(f"Failed to fetch CVEs for {product_name}.      │
│  Response: {response.text}")                                                 │
│                                                                              │
│          return [x["cve"] for x in response.json().get("rows")]              │
│                                                                              │
│      def _build_headers(self) -> dict:                                       │
│          """                                                                 │
│          Helper function to build headers with authentication information.   │
│          """                                                                 │
│                                                                              │
│          if not (self.client_id and self.token):                             │
│              raise ValueError("Client ID and/or Token are required for API   │
│  access.")                                                                   │
│                                                                              │
│          return {                                                            │
│              "Authorization": f"Bearer {self.api_token}",                    │
│          }                                                                   │
│                                                                              │
