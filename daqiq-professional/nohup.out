│      custom_logic_example = getattr(VulnerabilityScorer(),                   │
│  'custom_logic_dict')["CVE-2005-1234"]["custom_weighting_factor"]            │
│                                                                              │
│      print(f"Default score for CVE-2019-5463: {default_score}")              │
