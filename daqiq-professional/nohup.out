│          pdf_mimetype = "application/pdf"                                    │
│                                                                              │
│          # Open the PDF template and inject data from vulnerability list     │
│          try:                                                                │
│              with open(template_path, 'rb') as file:                         │
│                  template_pdf = MIMEBase(pdf_mimetype, 'PDF')                │
│                  template_pdf.set_payload(file.read())                       │
│                  encoders.encode_base64(template_pdf)                        │
│                                                                              │
│              attachment = MIMEMultipart()                                    │
│              attachment['Content-ID'] = '<attachment>'                       │
│              attachment.attach(MIMEText('Vulnerability Report', 'plain'))    │
│              attachment.attach(template_pdf)                                 │
