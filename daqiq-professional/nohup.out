│      async def main():                                                       │
│          slack_token = 'YOUR_SLACK_WEB_SOCKET_API_TOKEN'                     │
│                                                                              │
│          # Initialize the AsyncSlack object                                  │
│          slack_client = AsyncSlack(slack_token)                              │
│          await slack_client.connect()                                        │
│          asyncio.create_task(slack_client.event_listener('hello'))  #        │
