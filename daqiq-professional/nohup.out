│  if __name__ == "__main__":                                                  │
│      scanner = CommandInjectionScanner()                                     │
│                                                                              │
│      example_input = "dir | find \"\" | findstr 'hello world' 2>&1"          │
│                                                                              │
│      # Run the command injection scanner with an example input string.       │
