│          """                                                                 │
│          Scans a given file path. Returns True if the file is uploaded from  │
│  an allowed directory or does not show any signs of security vulnerability;  │
│           otherwise, returns False.                                          │
│                                                                              │
│          Parameters:                                                         │
│              file_path (str): The target file's full path to be scanned for  │
│  security issues.                                                            │
│                                                                              │
│          Returns:                                                            │
│              bool: True if no vulnerabilities are found, False if a          │
│  vulnerability is detected.                                                  │
│                    When False, the function reports suspicious activities    │
│  related to file upload origin and contents.                                 │
│          """                                                                 │
│          # Extract basic info from the URL of the request containing         │
│  potential malicious content                                                 │
│          url = urlparse(file_path)                                           │
│          host = os.path.basename(url.netloc)                                 │
│                                                                              │
│          sensitive_directories = ['/etc', '/tmp', '/proc', '/dev']           │
│                                                                              │
│          if any(keyword in file_path for keyword in ['../', '../../',        │
│  '../../../../../']):  # Directory traversal attempt detected                │
│              return True                                                     │
│                                                                              │
│          for potential_vulnerability_directory in sensitive_directories:     │
│              if os.path.commonprefix([file_path,                             │
│  os.path.join(potential_vulnerability_directory, '')]) == \                  │
│                      potential_vulnerability_directory:                      │
│                  print(f"Suspicious File Upload: Possible malicious file     │
│  detection - Path could traverse to critical system directory:               │
│  {potential_vulnerability_directory}")                                       │
│                  return True                                                 │
│                                                                              │
│          if any(path in self.safe_paths for path in                          │
│  urlparse(file_path).path):  # Checks if the file originates from an         │
│  allowed directory                                                           │
│              return False                                                    │
│                                                                              │
│          filename = os.path.basename(url.path)                               │
│                                                                              │
│          executable_extensions = [".exe", ".bat", ".com", ".cmd", ".js"]     │
│          if any(filename.endswith(ext) for ext in executable_extensions):    │
│              print(f"Suspicious File Upload: Executable file detected -      │
│  {filename} can be executed upon download.")                                 │
│              return True                                                     │
│                                                                              │
│          return False                                                        │
│                                                                              │
│                                                                              │
│  # Example Usage:                                                            │
│  def run_vulnerability_scan(target_directory: str, allowed_directories:      │
│  list):                                                                      │
│      """                                                                     │
│      Scans all files within the specified directory for security             │
│  vulnerabilities.                                                            │
│                                                                              │
│      Parameters:                                                             │
│      target_directory (str): The relative path to the target directory       │
│  where we scan for file uploads.                                             │
│      allowed_directories (list): A list of directories from which uploaded   │
│  files may originate.                                                        │
│                            Must include an absolute path, e.g.,              │
│  ['/path/to/uploaded/files'].                                                │
│                                                                              │
│      Returns: None                                                           │
│      """                                                                     │
│      scanner = FileUploadVulnerabilityScanner(allowed_directories)           │
│      for root, _, files in os.walk(target_directory):                        │
│          for file_ in files:                                                 │
│              full_path = os.path.join(root, file_)                           │
│              if not scanner.scan_file(full_path):                            │
│                  print(f"File uploaded from allowed directory and is not     │
│  suspicious: {full_path}")                                                   │
│                                                                              │
│  if __name__ == "__main__":                                                  │
│      target = "./uploads"                                                    │
│      allowed_directories = [os.getcwd()[:len(target) + 1] + 'uploads']  #    │
│  Path in your environment, replace with an appropriate root dir list.        │
│      run_vulnerability_scan(target=target,                                   │
│  allowed_directories=allowed_directories)                                    │
│  #                                                                           │
│  --------------------------------------------------------------------------  │
