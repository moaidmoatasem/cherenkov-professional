# mithaq Environment Configuration
# Copy this file to .env and adjust values as needed.
# Never commit .env to version control.

# Flask web server
FLASK_DEBUG=false
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Ollama (AI triage — Phase 4)
MITHAQ_OLLAMA_URL=http://localhost:11434
MITHAQ_OLLAMA_MODEL=qwen2.5-coder:7b

# FastAPI server (Phase 2+)
MITHAQ_API_HOST=127.0.0.1
MITHAQ_API_PORT=8000
MITHAQ_CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Database (Phase 2+)
# Leave unset to use default SQLite at ~/.mithaq/results.db
# MITHAQ_DB_URL=postgresql://user:pass@localhost/mithaq

