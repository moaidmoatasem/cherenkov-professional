# cherenkov Environment Configuration
# Copy this file to .env and adjust values as needed.
# Never commit .env to version control.

# Flask web server
FLASK_DEBUG=false
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Ollama (AI triage — Phase 4)
cherenkov_OLLAMA_URL=http://localhost:11434
cherenkov_OLLAMA_MODEL=qwen2.5-coder:7b

# FastAPI server (Phase 2+)
cherenkov_API_HOST=127.0.0.1
cherenkov_API_PORT=8000
cherenkov_CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Database (Phase 2+)
# Leave unset to use default SQLite at ~/.cherenkov/results.db
# cherenkov_DB_URL=postgresql://user:pass@localhost/cherenkov

# Rate limiting (slowapi) — override to relax limits in trusted environments
# Format: "<count>/<period>" where period is second/minute/hour/day
CHERENKOV_SCAN_RATE_LIMIT=20/minute
CHERENKOV_WORKFLOW_RATE_LIMIT=10/minute

