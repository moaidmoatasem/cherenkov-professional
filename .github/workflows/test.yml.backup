name: Tests

on:
  push:
    branches: [ main, feature/** ]
  pull_request:
    branches: [ main ]

jobs:
  test:
    runs-on: ubuntu-latest
    
    steps:
    - uses: actions/checkout@v4
    
    - name: Set up Python
      uses: actions/setup-python@v5
      with:
        python-version: '3.12'
    
    - name: Install dependencies
      run: |
        pip install -r daqiq-professional/requirements.txt
        pip install pytest pytest-cov
    
    - name: Run tests
      run: |
        cd daqiq-professional
        PYTHONPATH=src:. pytest tests/ -v --cov=src/daqiq --cov-report=xml
    
    - name: Upload coverage
      uses: codecov/codecov-action@v3
      with:
        file: ./daqiq-professional/coverage.xml
        fail_ci_if_error: false
