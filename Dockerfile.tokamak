# CHERENKOV TOKAMAK LITE (Community Edition)
# Purpose: Ephemeral, network-isolated detonation sandbox

FROM python:3.11

# Enforce Meissner zero-egress at the container level
# (Disables internet access during the run phase)
LABEL cherenkov.isolation.network="disabled"
LABEL cherenkov.perimeter="MEISSNER-LITE"

# Create a non-root user for detonation
RUN useradd -ms /bin/bash tokamak_user

WORKDIR /sandbox

# Copy the suspicious payload/PR into the sandbox
# Alignment fix: using packages/ instead of non-existent src/
COPY ./packages /sandbox/packages
COPY ./tests /sandbox/tests
COPY cherenkov_web.py /sandbox/cherenkov_web.py
COPY cherenkov_simple_scanner.py /sandbox/cherenkov_simple_scanner.py
COPY cherenkov_cli.py /sandbox/cherenkov_cli.py
COPY system_dashboard.py /sandbox/system_dashboard.py
COPY Dockerfile /sandbox/Dockerfile
COPY docker-compose.yml /sandbox/docker-compose.yml

# Install dependencies via pyproject.toml (requirements.txt removed — pyproject.toml is canonical)
COPY pyproject.toml ./
RUN pip install --no-cache-dir pytest pytest-asyncio pytest-cov httpx python-dotenv pydantic requests cryptography crewai pyyaml typer groq ollama fastapi

# Give tokamak_user write access to the entire sandbox
RUN chown -R tokamak_user:tokamak_user /sandbox

ENV PYTHONPATH=/sandbox/packages:/sandbox

# Drop privileges immediately
USER tokamak_user

# Cloud-API-dependent tests (groq, openai) are excluded — TOKAMAK runs air-gapped
ENV PYTHONPATH="/sandbox:${PYTHONPATH}"
CMD ["pytest", "tests/", \
     "--ignore=tests/packages/agents/cloud", \
     "--ignore=tests/packages/core/test_hybrid_orchestrator.py", \
     "--ignore=tests/packages/core/test_overseer.py", \
     "--ignore=tests/packages/core/test_parallel_agents.py", \
     "--ignore=tests/packages/crews", \
     "--ignore=tests/test_multi_agent_integration.py"]
