FROM python:3.14-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
    crewai \
    requests \
    flask \
    ollama \
    python-dotenv

# Copy application
COPY daqiq/ ./daqiq/
COPY *.py ./

# Create directories
RUN mkdir -p output logs

ENV PYTHONUNBUFFERED=1
ENV CREWAI_TELEMETRY_OPT_OUT=true

CMD ["python", "--version"]
